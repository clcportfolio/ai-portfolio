# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Reranker (optional — falls back to local BAAI/bge-reranker-base if unset) ─
COHERE_API_KEY=

# ── Structured storage (Supabase Session pooler URI) ─────────────────────────
SUPABASE_DB_URI=

# ── Vector store ──────────────────────────────────────────────────────────────
# QDRANT_MODE controls where the vector store lives:
#   embedded (default) — in-process Qdrant persisted to QDRANT_PATH. No Docker needed.
#                        Only one Python process can hold the lock at a time.
#   local              — connects to QDRANT_URL (e.g. Docker `docker run -p 6333:6333 qdrant/qdrant`)
#   cloud              — Qdrant Cloud free tier; requires QDRANT_URL + QDRANT_API_KEY
QDRANT_MODE=embedded
QDRANT_PATH=./qdrant_data
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=influencer_posts

# ── Cache (optional — pipeline runs without it, just no cache reuse) ──────────
REDIS_URL=
