# Anthropic — required for all LLM calls
ANTHROPIC_API_KEY=

# Langfuse — required for observability (create a project at cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# AWS S3 — required for file storage
# Create an IAM user with AmazonS3FullAccess and generate an access key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Supabase — required for structured data storage and NL2SQL
# Found at: Supabase project → Connect → Connection string (URI format)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URI=

# Redis — optional, enables real rate limiting and the traffic indicator in the UI
# Without this, rate limiting falls back to stub behaviour (always permits)
# Local: redis://localhost:6379
# Managed: use your provider's connection URL (Redis Cloud, Upstash, etc.)
REDIS_URL=
