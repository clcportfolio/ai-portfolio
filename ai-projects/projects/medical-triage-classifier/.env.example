# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # Required for Claude classification baseline + synthetic data gen

# ── Langfuse ───────────────────────────────────────────────────────────────────
# Create a separate Langfuse project: "medical-triage-classifier"
LANGFUSE_PUBLIC_KEY=                  # pk-lf-...
LANGFUSE_SECRET_KEY=                  # sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Stores: raw dataset CSV, training checkpoints, final model artifacts
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=                       # e.g. medical-triage-classifier-artifacts

# ── MLflow ────────────────────────────────────────────────────────────────────
# Local: http://localhost:5000 (run `mlflow ui` locally)
# EC2:   http://<ec2-public-ip>:5000
MLFLOW_TRACKING_URI=http://localhost:5000
