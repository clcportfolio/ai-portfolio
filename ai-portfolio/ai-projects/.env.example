# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # Required for all LLM calls via LangChain

# ── Langfuse ───────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=                  # Get from langfuse.com → Project Settings
LANGFUSE_SECRET_KEY=                  # Get from langfuse.com → Project Settings
LANGFUSE_HOST=https://cloud.langfuse.com

# ── HuggingFace ────────────────────────────────────────────────────────────────
HUGGINGFACE_API_KEY=                  # Only needed if using HF Inference API
                                      # Local HuggingFaceEmbeddings do NOT need this

# ── AWS (optional, free tier only) ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
