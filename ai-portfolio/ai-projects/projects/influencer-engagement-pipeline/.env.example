# ── Fully Local Pipeline — No External API Keys Required ─────────────────────

# MLflow — local tracking server with SQLite backend
# Start server: mlflow server --backend-store-uri sqlite:///data/mlflow/mlflow.db --default-artifact-root ./data/mlflow/artifacts --port 5050
MLFLOW_TRACKING_URI=http://localhost:5050

# Airflow — standalone mode
AIRFLOW_HOME=./airflow_home

# Kaggle — only needed for automated dataset download
# Get your token from https://www.kaggle.com/settings > "Create New Token"
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional: Redis for rate limiting (guardrails.py falls back to True if unset)
REDIS_URL=
