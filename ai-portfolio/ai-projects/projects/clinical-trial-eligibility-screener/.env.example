# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # Required for all LLM calls via LangChain

# ── Langfuse ───────────────────────────────────────────────────────────────────
# Create a separate Langfuse project for this screener so traces stay scoped.
# langfuse.com → New Project → "clinical-trial-eligibility-screener"
LANGFUSE_PUBLIC_KEY=                  # pk-lf-...
LANGFUSE_SECRET_KEY=                  # sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Supabase ───────────────────────────────────────────────────────────────────
# Use the Session pooler URI from Supabase Connect modal (not Direct or Transaction).
# Session pooler works on IPv4 (local dev + Streamlit Community Cloud).
SUPABASE_DB_URI=                      # postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
